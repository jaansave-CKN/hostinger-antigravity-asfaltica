# Copiar a .env y llenar con valores reales antes de desplegar.
# NUNCA commitear el archivo .env real — solo este .env.example con valores vacíos.

PORT=5180

# Clave compartida para el portón de acceso (/gate.html). Cambiar antes de publicar.
SITE_PASSWORD=

# Secreto de firma de sesión. Generar uno real con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
